{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "enabledManagers": ["npm", "nodenv", "github-actions"],
  "extends": ["config:recommended", "helpers:pinGitHubActionDigests"],
	"packageRules": [
	  {
      "groupName": "Slidev",
      "matchManagers": ["npm"],
      "matchPackageNames": [
        "@slidev/cli",
        "@slidev/types"
      ]
    }
	],
  "minimumReleaseAge": "7 days"
}
